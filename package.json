{
  "name": "smooth-notification",
  "version": "0.1.0",
  "description": "Toast · Modal · Confirm · Alert for React",
  "author": "ftery0",
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./dist/smooth.css": "./dist/smooth.css"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "react",
    "toast",
    "notification",
    "modal",
    "confirm",
    "alert",
    "dialog"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ftery0/SmoothNotification"
  },
  "scripts": {
    "start": "cd playground && yarn dev",
    "build": "tsup && yarn build:css",
    "build:css": "sass src/styles/smooth.scss dist/smooth.css --no-source-map",
    "test": "cypress open --component"
  },
  "peerDependencies": {
    "react": ">=17",
    "react-dom": ">=17"
  },
  "devDependencies": {
    "@cypress/code-coverage": "^3.13.7",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.16.0",
    "@vitejs/plugin-react": "^4.3.4",
    "cypress": "^13.16.0",
    "eslint": "^9.15.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "husky": "^9.1.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sass": "^1.81.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.1",
    "vite-plugin-istanbul": "^6.0.2"
  },
  "dependencies": {}
}
